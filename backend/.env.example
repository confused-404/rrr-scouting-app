# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Backend Runtime
NODE_ENV=production

# Frontend URL(s) for CORS.
# Use a comma-separated list for exact origins, including preview or custom domains.
FRONTEND_URL=https://your-frontend-domain.vercel.app
CORS_ORIGINS=https://preview-frontend-domain.vercel.app,https://another-allowed-origin.example.com

# SMTP settings used for password reset emails
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false   # set true for port 465
EMAIL_USER=your@email.com
EMAIL_PASS=supersecret

# you may instead supply a Brevo/SendinBlue API key and omit the SMTP
# settings entirely; the mailer will prefer BREVO_API_KEY when present.
BREVO_API_KEY=your-brevo-api-key-here
